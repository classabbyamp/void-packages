# Template file for 'vscode-bin'
pkgname=vscode-bin
version=1.83.1
revision=1
archs="x86_64"
depends="lsof xdg-utils"
short_desc="Microsoft Code for Linux (official binary)"
maintainer="classabbyamp <void@placeviolette.net>"
license="custom:Commercial"
homepage="https://code.visualstudio.com"
distfiles="https://update.code.visualstudio.com/${version}/linux-x64/stable>vscode-${version}.tar.gz"
checksum=17032e9b04671a941fcd3174576838afc60375b071d8d5835d4fe8f7d585c180
nopie=yes

post_extract() {
	_TELEMETRY_URLS="(dc\.services\.visualstudio\.com)|(vortex\.data\.microsoft\.com)|(mobile\.events\.data\.microsoft\.com)"
	_REPLACEMENT="s/$_TELEMETRY_URLS/0\.0\.0\.0/g"
	grep -rl -E $_TELEMETRY_URLS | xargs sed -i -E $_REPLACEMENT
}

do_install() {
	vmkdir usr/bin
	ln -s /usr/lib/code/bin/code "${DESTDIR}"/usr/bin/code

	vmkdir usr/lib/code
	vcopy '*' usr/lib/code

	vcompletion resources/completions/bash/code bash code
	vcompletion resources/completions/zsh/_code zsh code

	vinstall "${FILESDIR}"/code.desktop 644 usr/share/applications
	vinstall "${FILESDIR}"/code-url-handler.desktop 644 usr/share/applications
	vinstall "${FILESDIR}"/code-workspace.xml 644 usr/share/mime/packages

	vlicense resources/app/LICENSE.rtf
}
